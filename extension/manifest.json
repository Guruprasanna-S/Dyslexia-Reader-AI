{
  "manifest_version": 3,
  "name": "Dyslexia Reader AI",
  "version": "1.0",
  "description": "AI-powered reading assistant with simplification, definitions, and visual aids.",
  "permissions": ["activeTab", "scripting", "contextMenus", "tts"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}